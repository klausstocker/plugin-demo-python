# Copy this file to .env and fill in the values before running docker-compose.
# docker-compose.python.yml reads this file automatically for variable substitution.

# --- LeTTo setup-service ---
# Base URL of the LeTTo setup/config service (e.g. http://letto-setup:8096)
LETTO_SETUP_URI=

# Credentials for the setup-service "user" account used to register this plugin
SERVICE_USER_PASSWORD=

# --- Networking ---
# Hostname / address of this container within the Docker network nw-letto
NETWORK_LETTO_ADDRESS=letto-plugindemo-python

# Docker container name (must be unique across all LeTTo services)
DOCKER_CONTAINER_NAME=letto-plugindemo-python

# Internal URI passed to the setup service (leave empty to auto-derive from NETWORK_LETTO_ADDRESS)
LETTO_PLUGIN_URI_INTERN=

# External URI passed to the setup service (leave empty if not publicly reachable)
LETTO_PLUGIN_URI_EXTERN=

# --- Resource limits ---
# Memory limit for the container (e.g. 512m, 1g)
PLUGINDEMO_MEMORY_LIMIT=1g

# Host port to expose the plugin HTTP endpoint on
PLUGINDEMO_PORT=8080
